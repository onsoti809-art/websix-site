# ---- Server ----
PORT=8080
APP_URL=https://websix.site
# Comma-separated list of allowed origins for the browser (your site + local dev)
CORS_ORIGINS=https://websix.site,http://localhost:3000

# ---- Database ----
# Production: PostgreSQL (Supabase, Neon, Railway, RDS, etc.)
DATABASE_URL="postgresql://user:password@host:5432/websix?schema=public"

# ---- Auth ----
JWT_SECRET=replace-with-a-long-random-string
# Optional one-time token to allow creating the first admin via /api/auth/register
ADMIN_BOOTSTRAP_TOKEN=

# ---- Email (SMTP) ----
# Use a Gmail App Password (Google Account > Security > App passwords) for websixagency@gmail.com,
# or an SMTP-capable provider like Resend / Postmark / Mailgun.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=websixagency@gmail.com
SMTP_PASS=your-16-char-app-password
FROM_EMAIL="Websix <websixagency@gmail.com>"
# Where owner notifications go (defaults to SMTP_USER if blank)
OWNER_EMAIL=websixagency@gmail.com

# ---- Stripe (payments) ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
