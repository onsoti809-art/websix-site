{
  "name": "websix-cf-backend",
  "private": true,
  "type": "module",
  "description": "Websix agency backend on Cloudflare Workers + D1. Core services + Resend notifications.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:migrate": "wrangler d1 migrations apply websix-db --remote",
    "d1:migrate:local": "wrangler d1 migrations apply websix-db --local",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.5.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240821.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0"
  }
}
